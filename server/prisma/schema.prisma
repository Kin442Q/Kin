// ============================================================================
// KinderCRM Prisma schema
// PostgreSQL 16. Денежные поля — Decimal(12, 2) для точности.
// Используется индексирование по горячим путям. Партиционирование в будущем
// (Attendance, AuditLog) реализуется на уровне SQL-миграции.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE      // ходит сейчас
  ON_HOLD     // временно не ходит (отпуск/болезнь длительная)
  ARCHIVED    // выпустился / отчислен
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  SICK
  VACATION
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ExpenseCategory {
  SALARIES        // зарплаты сотрудников
  TAXES           // налоги
  RENT            // аренда
  UTILITIES       // коммуналка
  FOOD            // питание
  TOYS            // игрушки и инвентарь
  STATIONERY      // канцелярия
  INTERNET        // интернет и связь
  CLEANING        // уборка и хозтовары
  REPAIRS         // ремонт
  EDUCATION       // учебные материалы
  OTHER
}

enum StaffPosition {
  TEACHER_ASSISTANT
  HEAD_MASTER
  METHODIST
  NURSE
  COOK
  PSYCHOLOGIST
  MUSIC_TEACHER
  GUARD
  CLEANER
  OTHER
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  TELEGRAM
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
}

// ---------------------------------------------------------------------------
// KINDERGARTEN (мульти-тенант: каждый садик = отдельный изолированный аккаунт)
// ---------------------------------------------------------------------------

model Kindergarten {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique  // короткий ID для URL/команд
  address       String?
  phone         String?
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  groups        Group[]
  students      Student[]
  expenses      Expense[]
  extraIncomes  ExtraIncome[]
  staff         Staff[]
  menuItems     MenuItem[]

  @@index([isActive])
}

// ---------------------------------------------------------------------------
// MENU (питание)
// ---------------------------------------------------------------------------

enum MealType {
  BREAKFAST
  LUNCH
  SNACK
  DINNER
}

model MenuItem {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  meal        MealType
  title       String
  description String?
  calories    Int?

  kindergartenId String
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kindergartenId, date])
  @@index([date])
}

// ---------------------------------------------------------------------------
// STAFF (сотрудники садика, не учителя — для них есть User с role=TEACHER)
// ---------------------------------------------------------------------------

model Staff {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  middleName   String?
  position     StaffPosition
  phone        String
  email        String?
  /// id группы, если сотрудник закреплён за группой (например, помощник воспитателя)
  groupId      String?
  salary       Decimal  @db.Decimal(12, 2) @default(0)
  hireDate     DateTime

  kindergartenId String
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([kindergartenId])
  @@index([position])
}

// ---------------------------------------------------------------------------
// USERS / AUTH
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          Role     @default(TEACHER)
  avatarUrl     String?
  phone         String?

  /// Для multi-tenant: к какому садику принадлежит пользователь.
  /// NULL = глобальный супер-админ, видит все садики.
  kindergartenId String?
  kindergarten   Kindergarten? @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  /// Для TEACHER — id привязанной группы.
  /// (Может остаться NULL, пока админ не назначит группу.)
  groupId       String?
  group         Group?   @relation("GroupTeachers", fields: [groupId], references: [id], onDelete: SetNull)

  /// Для PARENT — id ребёнка.
  childId       String?
  child         Student? @relation(fields: [childId], references: [id])

  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]      @relation("AuditActor")
  notifications Notification[]

  @@index([role])
  @@index([groupId])
  @@index([kindergartenId])
}

/// Refresh-токены хранятся в БД, чтобы их можно было отзывать.
/// `tokenHash` — sha256 от самого токена, сам токен не сохраняем.
model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  jti        String   @unique
  tokenHash  String
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// GROUPS
// ---------------------------------------------------------------------------

model Group {
  id                   String   @id @default(cuid())
  name                 String
  ageRange             String         // "3–4 года"
  capacity             Int      @default(20)
  monthlyFee           Decimal  @db.Decimal(12, 2) @default(0)
  /// Фикс. ежемесячные расходы на группу (питание, материалы и т.п.)
  fixedMonthlyExpense  Decimal  @db.Decimal(12, 2) @default(0)
  color                String   @default("#6366f1")
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  /// Multi-tenant: к какому садику принадлежит группа
  kindergartenId       String?
  kindergarten         Kindergarten? @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  students             Student[]
  teachers             User[]          @relation("GroupTeachers")
  schedule             ScheduleItem[]
  expenses             Expense[]
  extraIncomes         ExtraIncome[]
  attendance           Attendance[]
  salaries             Salary[]
  monthlyReports       MonthlyReport[]

  @@index([isActive])
  @@index([kindergartenId])
}

// ---------------------------------------------------------------------------
// STUDENTS (Дети)
// ---------------------------------------------------------------------------

model Student {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  middleName    String?
  birthDate     DateTime
  gender        Gender
  photoUrl      String?
  medicalNotes  String?
  notes         String?

  // Родители
  motherName    String?
  motherPhone   String?
  fatherName    String?
  fatherPhone   String?
  address       String?
  extraContact  String?
  telegram      String?
  whatsapp      String?

  /// Индивидуальная плата (если не задано — берётся из group.monthlyFee).
  monthlyFee    Decimal? @db.Decimal(12, 2)

  status        StudentStatus @default(ACTIVE)
  enrolledAt    DateTime      @default(now())
  archivedAt    DateTime?

  groupId       String
  group         Group         @relation(fields: [groupId], references: [id])

  /// Multi-tenant: к какому садику принадлежит ребёнок
  kindergartenId String?
  kindergarten   Kindergarten? @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  attendance    Attendance[]
  payments      Payment[]
  parents       User[]        // PARENT-аккаунты, привязанные к ребёнку

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([groupId])
  @@index([status])
  @@index([lastName, firstName])
  @@index([kindergartenId])
}

// ---------------------------------------------------------------------------
// SCHEDULE
// ---------------------------------------------------------------------------

model ScheduleItem {
  id         String   @id @default(cuid())
  groupId    String
  dayOfWeek  Int      // 1..7 (Mon..Sun)
  startTime  String   // "HH:mm"
  endTime    String
  activity   String
  createdAt  DateTime @default(now())

  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, dayOfWeek])
}

// ---------------------------------------------------------------------------
// ATTENDANCE
// ---------------------------------------------------------------------------

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  groupId    String            // денормализуем для быстрых запросов по группе
  date       DateTime          @db.Date
  status     AttendanceStatus
  note       String?
  markedById String?           // id пользователя, который отметил
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group      Group             @relation(fields: [groupId], references: [id])

  @@unique([studentId, date])
  @@index([groupId, date])
  @@index([date])
}

// ---------------------------------------------------------------------------
// PAYMENTS (доход от родителей)
// ---------------------------------------------------------------------------

model Payment {
  id         String         @id @default(cuid())
  studentId  String
  month      String         // "YYYY-MM"
  amount     Decimal        @db.Decimal(12, 2)
  paid       Boolean        @default(false)
  paidAt     DateTime?
  method     PaymentMethod?
  comment    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  student    Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month])
  @@index([month, paid])
}

// ---------------------------------------------------------------------------
// EXTRA INCOME (доп. услуги, кружки, утренники)
// ---------------------------------------------------------------------------

model ExtraIncome {
  id        String   @id @default(cuid())
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  month     String
  groupId   String?
  comment   String?
  createdAt DateTime @default(now())

  group     Group?   @relation(fields: [groupId], references: [id])

  /// Multi-tenant
  kindergartenId String?
  kindergarten   Kindergarten? @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  @@index([month])
  @@index([groupId, month])
  @@index([kindergartenId])
}

// ---------------------------------------------------------------------------
// EXPENSES
// ---------------------------------------------------------------------------

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(12, 2)
  month       String
  groupId     String?         // NULL = общий расход (распределяется пропорционально детям)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  group       Group?          @relation(fields: [groupId], references: [id])

  /// Multi-tenant
  kindergartenId String?
  kindergarten   Kindergarten? @relation(fields: [kindergartenId], references: [id], onDelete: Cascade)

  @@index([month])
  @@index([groupId, month])
  @@index([month, category])
  @@index([kindergartenId])
}

// ---------------------------------------------------------------------------
// SALARIES
// ---------------------------------------------------------------------------

model Salary {
  id         String   @id @default(cuid())
  teacherId  String
  groupId    String?
  month      String
  amount     Decimal  @db.Decimal(12, 2)
  paid       Boolean  @default(false)
  paidAt     DateTime?
  comment    String?
  createdAt  DateTime @default(now())

  group      Group?   @relation(fields: [groupId], references: [id])

  @@unique([teacherId, month])
  @@index([month])
}

// ---------------------------------------------------------------------------
// MONTHLY REPORT (агрегированные итоги по группе — кэш на уровне БД)
// ---------------------------------------------------------------------------

model MonthlyReport {
  id            String   @id @default(cuid())
  groupId       String
  month         String
  studentsCount Int
  paidCount     Int
  debtorsCount  Int
  income        Decimal  @db.Decimal(14, 2)
  expenses      Decimal  @db.Decimal(14, 2)
  profit        Decimal  @db.Decimal(14, 2)
  margin        Decimal  @db.Decimal(6, 4)   // -1..1
  attendanceRate Decimal @db.Decimal(5, 4)   // 0..1
  generatedAt   DateTime @default(now())

  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, month])
  @@index([month])
}

// ---------------------------------------------------------------------------
// PHONE → TELEGRAM CHAT LINKS (привязка телефонов родителей к Telegram чатам)
// ---------------------------------------------------------------------------

model PhoneChatLink {
  id            String   @id @default(cuid())
  /// Нормализованный номер телефона (только цифры, без + и пробелов)
  phoneNormalized String @unique
  /// Telegram chat ID родителя
  chatId        BigInt
  /// Имя/фамилия из профиля Telegram (для отладки)
  fullName      String?
  username      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([chatId])
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id          String              @id @default(cuid())
  userId      String?
  title       String
  description String?
  type        NotificationType    @default(INFO)
  channel     NotificationChannel @default(IN_APP)
  read        Boolean             @default(false)
  payload     Json?
  createdAt   DateTime            @default(now())

  user        User?               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------------

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  action    AuditAction
  entity    String      // "Student", "Group", …
  entityId  String?
  diff      Json?       // {before, after}
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  actor     User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
}
