# Скопируйте этот файл в .env и заполните своими значениями.
NODE_ENV=development
PORT=4000

# PostgreSQL connection string (например, для docker-compose):
DATABASE_URL="postgresql://kg_user:kg_pass@localhost:5432/kg_db?schema=public"

# Секрет JWT — обязательно поменяйте в продакшене
JWT_SECRET="super-secret-change-me"

# CORS — список разрешённых источников через запятую
CORS_ORIGIN="http://localhost:5173"
