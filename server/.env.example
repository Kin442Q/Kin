# ============================================================================
# KinderCRM Backend (NestJS) — пример .env. Скопируйте в .env и поменяйте секреты.
# ============================================================================

NODE_ENV=development
PORT=4000

# CORS — список разрешённых origin-ов через запятую
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://kg_user:kg_pass@localhost:5432/kg_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT (минимум 16 символов в проде, генерируйте через openssl rand -hex 64)
JWT_ACCESS_SECRET=replace-me-access-secret-min-16
JWT_REFRESH_SECRET=replace-me-refresh-secret-min-16
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Throttling: limit запросов / ttl сек
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Telegram (для уведомлений). Если пусто — TelegramProcessor просто логирует.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
